<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>recipe-extraction</string>
	</array>
	
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
	</array>
	
	<!-- Exported Type Declarations: Registers file types that your app owns -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<!-- Recipe Book Package Type -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.headydiscy.reczipes.recipebook</string>
			<key>UTTypeDescription</key>
			<string>Recipe Book Package</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.zip-archive</string>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>recipebook</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-recipebook</string>
				</array>
			</dict>
			<key>UTTypeIconFiles</key>
			<array/>
		</dict>
		<!-- Reczipes Backup Type -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.reczipes.backup</string>
			<key>UTTypeDescription</key>
			<string>Reczipes Backup File</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>reczipes</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/json</string>
				</array>
			</dict>
			<key>UTTypeIcons</key>
			<dict/>
		</dict>
	</array>
	
	<!-- Document Types: Declares that your app can open these file types -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<!-- Recipe Book Document Type -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Recipe Book</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.headydiscy.reczipes.recipebook</string>
			</array>
		</dict>
		<!-- Reczipes Backup Document Type -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Reczipes Backup</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.reczipes.backup</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
